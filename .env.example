# ============================================
# DATAGUARD MX - CONFIGURACIÓN DE ENTORNO
# ============================================

# --------------------------------------------
# 1️⃣ SERVIDOR
# --------------------------------------------
PORT=3001
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001
NODE_ENV=development

# --------------------------------------------
# 2️⃣ SUPABASE - BASE DE DATOS
# --------------------------------------------
# Obtén estos valores desde: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://tu_proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# --------------------------------------------
# 3️⃣ JWT - AUTENTICACIÓN
# --------------------------------------------
# Genera una clave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_muy_seguro_cambia_esto
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# 4️⃣ GMAIL - CONFIGURACIÓN DE CORREO
# --------------------------------------------
# Para usar Gmail, necesitas una contraseña de aplicación:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion_16_digitos
EMAIL_FROM=tu_correo@gmail.com

# Para Outlook/Hotmail:
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587

# Para Yahoo:
# EMAIL_HOST=smtp.mail.yahoo.com
# EMAIL_PORT=465

# --------------------------------------------
# 5️⃣ N8N - AUTOMATIZACIÓN
# --------------------------------------------
# URL del webhook de n8n para el chatbot
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# --------------------------------------------
# 6️⃣ BREACHDIRECTORY - VERIFICACIÓN DE FILTRACIONES
# --------------------------------------------
# Obtén una API Key gratis en: https://rapidapi.com/rohan-patra/api/breachdirectory
RAPIDAPI_KEY=tu_rapidapi_key_aqui
RAPIDAPI_HOST=breachdirectory.p.rapidapi.com
HIBP_ENABLED=true
FEATURE_BREACH_CHECK=true

# --------------------------------------------
# 7️⃣ FEATURE FLAGS (Activar/Desactivar características)
# --------------------------------------------
FEATURE_EMAIL_NOTIFICATIONS=true      # Enviar notificaciones por email
FEATURE_PDF_EXPORT=true               # Permitir exportación a PDF
FEATURE_2FA=false                     # Autenticación de dos factores (en desarrollo)
FEATURE_CHATBOT=true                  # Habilitar chatbot

# --------------------------------------------
# 8️⃣ SEGURIDAD ADICIONAL
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000           # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100           # Máximo 100 peticiones por IP
CORS_ORIGIN=http://localhost:3001     # Orígenes permitidos (separar por comas)

# --------------------------------------------
# 9️⃣ LOGGING
# --------------------------------------------
LOG_LEVEL=info                        # debug, info, warn, error
LOG_FORMAT=combined                   # combined, common, dev, short, tiny

# --------------------------------------------
# 🔟 CONFIGURACIÓN DE SESIÓN
# --------------------------------------------
SESSION_SECRET=tu_session_secret_cambia_esto
SESSION_MAX_AGE=86400000              # 24 horas (en milisegundos)

# --------------------------------------------
# 1️⃣1️⃣ ALMACENAMIENTO DE ARCHIVOS
# --------------------------------------------
UPLOAD_MAX_SIZE=10mb                  # Tamaño máximo de archivos subidos
TEMP_DIR=./temp                       # Directorio para archivos temporales
PDF_STORAGE_PATH=./storage/pdfs       # Directorio para PDFs generados

# --------------------------------------------
# 1️⃣2️⃣ WAHA - WHATSAPP HTTP API (Opcional)
# --------------------------------------------
# Para enviar notificaciones por WhatsApp (opcional)
WAHA_URL=http://localhost:3000
WAHA_API_KEY=tu_waha_api_key
WAHA_SESSION=dataguard
ADMIN_WHATSAPP_NUMBER=521234567890     # Número del administrador (formato: 521234567890)

# --------------------------------------------
# 1️⃣3️⃣ TWILIO - WHATSAPP (Alternativa a WAHA)
# --------------------------------------------
# TWILIO_ACCOUNT_SID=tu_account_sid
# TWILIO_AUTH_TOKEN=tu_auth_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --------------------------------------------
# 1️⃣4️⃣ GEMINI AI - CHATBOT AVANZADO (Opcional)
# --------------------------------------------
# GEMINI_API_KEY=tu_gemini_api_key

# --------------------------------------------
# 1️⃣5️⃣ MONITOREO Y MÉTRICAS
# --------------------------------------------
METRICS_ENABLED=false
METRICS_PORT=9090