      "parameters": {
        "jsCode": "if ($json.error) {\n  return [{ json: { reply: '⚠️ Error al obtener alertas. Intenta más tarde.' } }];\n}\n\nconst lista = Array.isArray($json) ? $json : ($json.data || []);\nconst total = lista.length;\n\nlet nivel = 'BAJO';\nlet emoji = '🟢';\nif (total >= 3) { nivel = 'ALTO';  emoji = '🔴'; }\nelse if (total >= 1) { nivel = 'MEDIO'; emoji = '🟠'; }\n\nreturn [{ json: { reply: `${emoji} Nivel de riesgo: ${nivel}\\nTienes ${total} alertas. Revisa tu dashboard.` } }];"
