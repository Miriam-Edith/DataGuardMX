      "parameters": {
        "jsCode": "function normalize(text) {\n  return text\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '');\n}\n\nconst raw = $json.body?.message || '';\nconst mensaje = normalize(raw);\nconst userId = $json.body?.userId || null;\n\nconst intents = {\n  riesgo:  ['riesgo','alertas','seguridad','filtracion','hackeo'],\n  arco:    ['arco','datos','privacidad','acceso','rectificacion','cancelacion'],\n  reporte: ['reporte','denuncia','queja','incidente'],\n  ayuda:   ['ayuda','menu','opciones']\n};\n\nconst priority = ['riesgo','arco','reporte','ayuda'];\n\nfunction detectar(texto) {\n  for (const intent of priority) {\n    for (const palabra of intents[intent]) {\n      if (texto.includes(palabra)) return intent;\n    }\n  }\n  return 'gemini';\n}\n\nreturn [{ json: { mensaje, raw, userId, intent: detectar(mensaje) } }];"
      },
